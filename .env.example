# ── Remnawave connection ───────────────────────────────
REMNAWAVE_BASE_URL=https://your-panel.example.com
REMNAWAVE_TOKEN=your-api-token-here

# ── Test user defaults ─────────────────────────────────
TEST_TRAFFIC_LIMIT_GB=0.05
TEST_EXPIRE_DAYS=1
TEST_TRAFFIC_RESET_STRATEGY=NO_RESET   # NO_RESET | DAY | WEEK | MONTH | YEAR

# ── Assignments (optional, leave empty to skip) ────────
TEST_TAG=TEST
TEST_INTERNAL_SQUAD_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEST_EXTERNAL_SQUAD_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
